# ── PostgreSQL ──
POSTGRES_USER=hankoduko
POSTGRES_PASSWORD=          # openssl rand -base64 16 으로 생성
POSTGRES_DB=hankoduko

# ── Backend ──
JWT_SECRET=                 # openssl rand -base64 32 으로 생성
JWT_REFRESH_SECRET=         # openssl rand -base64 32 으로 생성
FRONTEND_URL=http://서버IP  # 도메인 연결 후 https://yourdomain.com 으로 변경

# ── Frontend (빌드 시 사용, docker-compose에서 build args로 전달) ──
# NEXT_PUBLIC_API_URL=/api  # 기본값 /api, 변경 불필요
